# Скопируй в .env ИЛИ задай как переменные окружения Windows.
# Реальный ключ в репозиторий не коммитим (.env в .gitignore).

# Ключ OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Тир моделей: dev (дёшево, отладка) | final (Claude, eval и демо)
SENSE_MODE=dev

# Личные контакты для слайда «Контакты» в презентации ИТМО. В коде их нет — репозиторий
# публичный. Без них слайд соберётся с плейсхолдерами шаблона.
SENSE_CONTACT_PHONE=+7 900 000 00 00
SENSE_CONTACT_EMAIL=you@example.com
