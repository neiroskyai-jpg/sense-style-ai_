.business/
.env
user-photos/
ab-output/

# данные трекинга (SQLite) — игнорируем содержимое data/, но не саму папку,
# чтобы можно было вернуть RAG-индекс в трекинг (он часть продукта)
data/*
!data/rag/
# каталог реальных вещей (публичные данные брендов, не ПДн) — нужен кабинету/конструктору,
# иначе визуальная капсула вырождается в текст. Только рантайм-файлы; тяжёлые capsules.json /
# capsule-showcase.md (офлайн-скрипты) не коммитим.
!data/fashion-base/
data/fashion-base/*
!data/fashion-base/products_ushatava.csv
!data/fashion-base/products_lichi.csv
!data/fashion-base/products_wb.csv
!data/fashion-base/brands.csv

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# служебное (инструментарий Claude Code — не часть проекта)
.agents/
.claude/
skills-lock.json
.mcp.json
.playwright-mcp/
node_modules/

# приватное: реальные имена клиенток (перс. данные) — не коммитим даже в приватный репо
architecture/cases/
# временные/служебные
.tmp-docs/
.tmp-render.py
*.jpeg
*.png
*.pdf

# сайт web/: картинки нужны для деплоя — возвращаем в трекинг,
# но PII клиенток (*case*) и любые pdf — НЕ коммитим
!web/**/*.png
!web/**/*.jpg
!web/**/*.jpeg
!web/**/*.webp
!web/**/*.svg
!web/**/*.gif
# кейсы клиенток (с согласием) — ФОТО показываем, но документы (PDF/офис) НЕ коммитим
web/**/*.pdf
web/**/*.pptx
web/**/*.docx
web/**/*.doc
web/**/*.xlsx
web/index-collage-backup.html
web/index-dwp-backup.html

# Курс (raw-inbox/course): исходные видео и временный звук НЕ коммитим;
# транскрипты (.txt/.srt) и ключевые кадры слайдов (.png) — коммитим.
architecture/reference/raw-inbox/course/inbox/*
!architecture/reference/raw-inbox/course/inbox/.gitkeep
architecture/reference/raw-inbox/course/**/*.wav
!architecture/reference/raw-inbox/course/slides/**/*.png

# Купленный «Скилл статей» (лицензия запрещает публикацию) + личные образцы голоса
statejnik/
statejnik/voice-samples/

# Образцы голоса — личные тексты не коммитим (README оставляем)
voice-samples/*
!voice-samples/README.md

# Лицензия купленного «Скилл статей» — выдана персонально, публикация в открытых
# репозиториях прямо запрещена её же условиями. Лежала в корне и попала в git.
statejnik-LICENSE.txt
LICENSE.txt
